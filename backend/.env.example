# SILENCEHUB - Backend
# Copier en .env et adapter les valeurs

NODE_ENV=development
PORT=5001

# Base de données
# Option 1 - JSON local (développement sans PostgreSQL)
# DATABASE_URL=json:./data/silencehub.json

# Option 2 - PostgreSQL local (Docker: docker compose up -d)
# DATABASE_URL=postgresql://silencehub:silencehub_dev@localhost:5432/silencehub

# Option 3 - Supabase
# DATABASE_URL=postgresql://postgres:MOT_DE_PASSE@db.begavtmnxocgynudzoxe.supabase.co:5432/postgres
# URL Supabase: https://begavtmnxocgynudzoxe.supabase.co

JWT_SECRET=change-me-in-production-xyz123
JWT_EXPIRES_IN=7d
JWT_ANONYMOUS_EXPIRES_IN=365d

ADMIN_EMAIL=admin@silencehub.local
ADMIN_PASSWORD=ChangeMe123!

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

CORS_ORIGIN=http://localhost:3000
