{
  "version": 2,
  "buildCommand": "cd backend && npm ci && cd ../frontend && npm ci && npm run build",
  "outputDirectory": "frontend/build",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api|_next|static|favicon|manifest|logo).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
