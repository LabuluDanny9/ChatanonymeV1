# Frontend - Variables d'environnement

# URL du backend
# - En dev avec proxy : laisser vide (le proxy redirige /api et /ws)
# - En dev sans proxy : http://localhost:5001
# - En production : https://votre-backend.railway.app
REACT_APP_API_URL=

# Chemin WebSocket (par défaut /ws)
REACT_APP_WS_PATH=/ws
